{
  "version": 1,
  "profile": {
    "name": "Default User",
    "notes": ""
  },
  "defaults": {
    "session": {
      "restore_on_launch": false,
      "remember_window_bounds": false
    },
    "ui": {
      "theme": "dark",
      "font_size": 14
    }
  },
  "language_prefs": {
    "python": {
      "venv": {
        "auto_enable_when_dependency_count_gte": 2,
        "venv_dir": ".venv",
        "python_executable": "python",
        "use_requirements_txt": false
      },
      "entrypoint": "main.py"
    }
  },
  "backup": {
    "enabled": false,
    "interval_minutes": 60,
    "retention_count": 4,
    "target_dir": ".supercli/backups",
    "compress": false
  },
  "integrations": {
    "github": {
      "enabled": true,
      "issue_state": "open",
      "labels": "",
      "comment_on_close": false,
      "close_comment": "Closed via SuperCLI.",
      "comment_on_reopen": false,
      "reopen_comment": "Reopened via SuperCLI."
    }
  }
}